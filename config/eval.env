# Canonical evaluation profile for one-command runs.
# Non-secret defaults live here; provide credentials via shell env.

EVAL_TARGET=easy-matrix

# Shared runtime defaults
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-5-mini
ALLOW_PACKAGE_REGISTRIES=false

# easy-button settings (used when EVAL_TARGET=easy)
EASY_MODE=job
TASK_REF=TASK_1
AGENT_NAME=zeroclaw
AGENT_IMAGE=zeroclaw-adapter:latest
WAIT_TIMEOUT=120s

# easy-matrix settings (used when EVAL_TARGET=easy-matrix)
AGENT_FILTER=
REPEAT_COUNT=1
MATRIX_STRICT=false
COMPARISON_MODE=available

# Hard run-budget guardrails (0 disables a guardrail)
MAX_TOTAL_RUNS=12
MAX_FAILED_RUNS=3
MAX_WALL_CLOCK_MIN=30
MAX_ANTHROPIC_RUNS=2

# Optional overrides for scripts
AGENT_MATRIX_FILE=config/agents.csv
AGENT_SAFETY_FILE=config/agents-safety.csv
REQUIRE_GITHUB_TOKEN=false
